{
  "name": "api",
  "version": "1.0.0",
  "description": "Limen API — Express + TypeScript backend with x402 and Supabase integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "vercel-build": "tsc"
  },
  "keywords": [
    "express",
    "typescript",
    "x402",
    "supabase",
    "api"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@privy-io/server-auth": "^1.32.5",
    "@supabase/supabase-js": "^2.78.0",
    "ai": "^5.0.83",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "x402-solana": "^0.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
