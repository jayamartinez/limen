# Root .env.example
# Copy this file to .env and distribute to apps/dashboard/.env.local and apps/api/.env

# Dashboard
NEXT_PUBLIC_API_BASE="http://localhost:3001"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_DEMO_MODE="false"

# Privy Authentication (Dashboard)
# Get from: Privy Dashboard > Settings > Basics
# Docs: https://docs.privy.io/basics/get-started/dashboard
NEXT_PUBLIC_PRIVY_APP_ID="insert-your-privy-app-id"

# API Configuration
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"

# Privy Server Authentication (API)
# Get from: Privy Dashboard > Settings > Basics
# Docs: https://docs.privy.io/basics/get-started/dashboard
PRIVY_APP_ID="insert-your-privy-app-id"
PRIVY_APP_SECRET="insert-your-privy-app-secret"

# Solana / x402
SOLANA_NETWORK="solana-devnet"
TREASURY_WALLET_ADDRESS="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"
FACILITATOR_URL="http://localhost:3001/api/pay"
MAX_PAYMENT_AMOUNT="100000"

# Mock Services
NEXT_PUBLIC_SUPABASE_URL="https://mock.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="mock"
GOOGLE_SEARCH_API_KEY="mock"
GOOGLE_SEARCH_ENGINE_ID="mock"
COINBASE_BEARER="mock"
